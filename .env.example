# Admin Authentication credentials (customize for your administrative access)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="YourStrongPasswordHere"

# Cryptographic token signing secret (32+ chars random string recommended)
# You can generate a random hex string with: node -e "console.log(require('crypto').randomBytes(20).toString('hex'))"
AUTH_SECRET="f39e802a9eb786a51cc247fdfd2b1f8938b2512f"

# UploadThing credentials
# UploadThing v6/v7 uses a single API token
UPLOADTHING_TOKEN="insert_your_uploadthing_token_here"

# Public storefront redirection location (redirects here after logout)
PUBLIC_WEBSITE_URL="http://localhost:3000"
